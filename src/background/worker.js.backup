// src/background/worker.js
// DeepSeek AgentTeam - Background Service Worker

const CONFIG = {
  MAX_LOGS: 500,
  DEFAULT_SEND_INTERVAL: 5000,
  DEFAULT_CLEANUP_INTERVAL: 3600000, // 1 hour
  TAB_LOAD_TIMEOUT: 30000,
  MAX_RETRIES: 3,
  RETRY_DELAY: 2000
};

// ==================== Data Storage ====================
let teams = {};
let teamLogs = [];
let teamProgress = {};
let teamTabs = {}; // teamId -> { memberName -> tabId }
let tabMemberMap = {}; // tabId -> { teamId, memberId }
let teamSessionState = {}; // sessionKey -> { promptSent: boolean, messages: [], active: boolean }
let conversationHistory = {}; // sessionKey -> [{role, content, timestamp}]

// ==================== Logger ====================
const Logger = {
  log(level, message, data = null) {
    const entry = {
      id: Date.now().toString(36) + Math.random().toString(36).substr(2),
      timestamp: Date.now(),
      level,
      message,
      data
    };
    teamLogs.unshift(entry);
    if (teamLogs.length > CONFIG.MAX_LOGS) {
      teamLogs = teamLogs.slice(0, CONFIG.MAX_LOGS);
    }
    chrome.storage.local.set({ teamLogs });
    return entry;
  },
  info(message, data) { return this.log('info', message, data); },
  warn(message, data) { return this.log('warn', message, data); },
  error(message, data) { return this.log('error', message, data); },
  debug(message, data) { return this.log('debug', message, data); }
};

// ==================== Team Status Updates ====================
async function broadcastTeamStatus(teamId, enabled) {
  const team = teams[teamId];
  if (!team) {
    Logger.error('Team not found for status broadcast', { teamId });
    return;
  }
  
  Logger.info('Broadcasting team status', { teamId, enabled, memberCount: team.members.length });
  
  for (const member of team.members) {
    if (member.tabId) {
      try {
        await chrome.tabs.sendMessage(member.tabId, {
          type: 'UPDATE_TEAM_STATUS',
          payload: { enabled }
        });
        Logger.debug('Team status sent to member', { memberId: member.id, tabId: member.tabId, enabled });
      } catch (err) {
        Logger.warn('Failed to send team status to member', { memberId: member.id, tabId: member.tabId, error: err.message });
      }
    }
  }
}

// ==================== Team Management ====================
function loadTeams() {
  chrome.storage.local.get(['teams'], (res) => {
    teams = res.teams || {};
    Logger.info('Teams loaded', { count: Object.keys(teams).length });
  });
  chrome.storage.local.get(['teamLogs'], (res) => {
    teamLogs = res.teamLogs || [];
  });
}

function saveTeams() {
  chrome.storage.local.set({ teams });
}

function createTeam(teamData) {
  const id = 'team_' + Date.now();
  const newTeam = {
    id,
    name: teamData.name,
    description: teamData.description || '',
    sharedPrompt: teamData.sharedPrompt || '',
    auxPrompt: teamData.auxPrompt || '',
    settings: {
      deepThink: teamData.settings?.deepThink || false,
      webSearch: teamData.settings?.webSearch || false,
      autoSwitch: teamData.settings?.autoSwitch !== false,
      sendInterval: teamData.settings?.sendInterval || CONFIG.DEFAULT_SEND_INTERVAL,
      cleanupInterval: teamData.settings?.cleanupInterval || 3600000,
      maxConcurrentConversations: teamData.settings?.maxConcurrentConversations || 0,
      individualMemory: teamData.settings?.individualMemory !== false,
      groupMemory: teamData.settings?.groupMemory !== false,
      reinforcementInterval: teamData.settings?.reinforcementInterval || 0, // 0表示不启用巩固，>0表示每N轮对话发送一次角色提示词
      autoContinue: teamData.settings?.autoContinue !== false, // 自动继续（选择推荐选项）
      autoForward: teamData.settings?.autoForward || false // 自动转发消息给其他成员
    },
    members: [],
    createdAt: Date.now()
  };
  teams[id] = newTeam;
  saveTeams();
  Logger.info('Team created', { teamId: id, name: newTeam.name });
  return newTeam;
}

function updateTeam(teamId, updates) {
  if (teams[teamId]) {
    Object.assign(teams[teamId], updates);
    saveTeams();
    Logger.info('Team updated', { teamId });
    return teams[teamId];
  }
  return null;
}

function deleteTeam(teamId) {
  delete teams[teamId];
  delete teamProgress[teamId];
  delete teamTabs[teamId];
  // Clean up session state
  Object.keys(teamSessionState).forEach(key => {
    if (key.startsWith(teamId + '_')) {
      delete teamSessionState[key];
    }
  });
  saveTeams();
  Logger.info('Team deleted', { teamId });
}

function addMember(teamId, memberData) {
  const team = teams[teamId];
  if (!team) return null;
  
  const member = {
    id: 'member_' + Date.now(),
    name: memberData.name,
    identifier: memberData.identifier || '',
    role: memberData.role || 'member',
    prompt: memberData.prompt || '',
    description: memberData.description || '',
    workflow: memberData.workflow || '',
    parentId: memberData.parentId || null,
    tabId: null,
    currentUrl: null, // 存储标签页的当前URL
    customUrl: memberData.customUrl || null, // 自定义URL（如果有）
    // Member-specific settings
    useTeamSettings: memberData.useTeamSettings !== false,
    deepThink: memberData.deepThink,
    webSearch: memberData.webSearch,
    createdAt: Date.now()
  };
  
  team.members.push(member);
  saveTeams();
  Logger.info('Member added', { teamId, memberId: member.id, name: member.name });
  return member;
}

function updateMember(teamId, memberId, updates) {
  const team = teams[teamId];
  if (!team) return null;
  
  const member = team.members.find(m => m.id === memberId);
  if (member) {
    // Handle member-specific settings
    const processedUpdates = { ...updates };
    if (updates.useTeamSettings !== undefined) {
      member.useTeamSettings = updates.useTeamSettings;
      if (updates.useTeamSettings) {
        // Clear member-specific settings when using team defaults
        member.deepThink = undefined;
        member.webSearch = undefined;
      }
    }
    if (!member.useTeamSettings) {
      if (updates.deepThink !== undefined) member.deepThink = updates.deepThink;
      if (updates.webSearch !== undefined) member.webSearch = updates.webSearch;
    }
    
    Object.assign(member, processedUpdates);
    saveTeams();
    Logger.info('Member updated', { teamId, memberId });
    return member;
  }
  return null;
}

function removeMember(teamId, memberId) {
  const team = teams[teamId];
  if (!team) return;
  
  const member = team.members.find(m => m.id === memberId);
  if (member && member.tabId) {
    chrome.tabs.remove(member.tabId).catch(() => {});
    delete tabMemberMap[member.tabId];
  }
  
  team.members = team.members.filter(m => m.id !== memberId);
  saveTeams();
  Logger.info('Member removed', { teamId, memberId });
}

// ==================== Tab Management ====================
async function createMemberTab(teamId, memberId, options = {}) {
  const team = teams[teamId];
  const member = team?.members.find(m => m.id === memberId);
  if (!member) {
    Logger.error('Member not found', { teamId, memberId });
    return null;
  }
  
  try {
    Logger.info('Creating tab for member', {
      teamId, memberId, memberName: member.name,
      customUrl: member.customUrl,
      autoSendInitialPrompt: options.autoSendInitialPrompt !== false // 默认true
    });
    
    // Use custom URL if provided, otherwise use default
    const url = member.customUrl || 'https://chat.deepseek.com';
    
    const tab = await chrome.tabs.create({
      url: url,
      active: false
    });
    
    Logger.info('Tab created successfully', { tabId: tab.id, teamId, memberId, url });
    
    member.tabId = tab.id;
    member.currentUrl = url; // 存储当前URL
    tabMemberMap[tab.id] = { teamId, memberId };
    
    if (!teamTabs[teamId]) teamTabs[teamId] = {};
    teamTabs[teamId][memberId] = tab.id;
    
    saveTeams();
    Logger.info('Tab saved', { tabId: tab.id, teamId, memberId, currentUrl: url });
    
    // 监听标签页加载完成事件，发送初始提示词（如果启用）
    if (options.autoSendInitialPrompt !== false) {
      chrome.tabs.onUpdated.addListener(function listener(tabId_, info) {
        if (tabId_ === tab.id && info.status === 'complete') {
          // 移除监听器
          chrome.tabs.onUpdated.removeListener(listener);
          
          // 等待页面完全初始化
          setTimeout(async () => {
            try {
              // 发送初始提示词
              await sendInitialPrompts(teamId, memberId);
              Logger.info('Initial prompts sent successfully', { teamId, memberId });
            } catch (err) {
              Logger.error('Failed to send initial prompts', { teamId, memberId, error: err.message });
            }
          }, 3000); // 等待3秒确保页面完全加载
        }
      });
    } else {
      Logger.info('Auto-send initial prompt disabled for this tab', { teamId, memberId });
    }
    
    return tab;
  } catch (err) {
    Logger.error('Failed to create tab', { teamId, memberId, error: err.message, errorStack: err.stack });
    return null;
  }
}

// 检查并确保成员标签页存在且URL正确
async function ensureMemberTab(teamId, memberId, options = {}) {
  const team = teams[teamId];
  const member = team?.members.find(m => m.id === memberId);
  if (!member) {
    Logger.error('Member not found for ensureMemberTab', { teamId, memberId });
    return null;
  }
  
  // 目标URL
  const targetUrl = member.customUrl || 'https://chat.deepseek.com';
  
  // 如果成员已经有标签页
  if (member.tabId) {
    try {
      // 检查标签页是否仍然存在
      const tab = await chrome.tabs.get(member.tabId);
      
      // 检查标签页URL是否匹配目标URL
      if (tab.url && tab.url.startsWith(targetUrl)) {
        // URL匹配，重用现有标签页
        Logger.info('Reusing existing tab', {
          teamId, memberId, tabId: member.tabId,
          currentUrl: tab.url, targetUrl,
          autoSendInitialPrompt: options.autoSendInitialPrompt
        });
        
        // 更新存储的URL
        member.currentUrl = tab.url;
        saveTeams();
        
        return tab;
      } else {
        // URL不匹配，导航到目标URL
        Logger.info('Tab URL mismatch, navigating', {
          teamId, memberId, tabId: member.tabId,
          currentUrl: tab.url, targetUrl,
          autoSendInitialPrompt: options.autoSendInitialPrompt
        });
        
        const updatedTab = await chrome.tabs.update(member.tabId, { url: targetUrl });
        member.currentUrl = targetUrl;
        saveTeams();
        
        return updatedTab;
      }
    } catch (err) {
      // 标签页不存在（可能被用户关闭）
      Logger.warn('Tab no longer exists, creating new one', {
        teamId, memberId, tabId: member.tabId, error: err.message
      });
      member.tabId = null;
      member.currentUrl = null;
    }
  }
  
  // 创建新标签页，传递options参数
  return await createMemberTab(teamId, memberId, options);
}

function closeMemberTab(teamId, memberId) {
  const team = teams[teamId];
  const member = team?.members.find(m => m.id === memberId);
  if (member?.tabId) {
    chrome.tabs.remove(member.tabId).catch(() => {});
    delete tabMemberMap[member.tabId];
    delete teamTabs[teamId]?.[memberId];
    member.tabId = null;
    saveTeams();
  }
}

async function switchToTab(tabId) {
  try {
    // First check if tab exists
    const tab = await chrome.tabs.get(tabId);
    if (!tab) {
      Logger.error('Tab not found', { tabId });
      return false;
    }
    
    await chrome.tabs.update(tabId, { active: true });
    
    // Try to focus the window
    try {
      const win = await chrome.windows.get(tab.windowId);
      await chrome.windows.update(win.id, { focused: true });
    } catch (winErr) {
      // Window focus is less critical, just log
      Logger.debug('Could not focus window', { tabId, error: winErr.message });
    }
    
    Logger.info('Switched to tab', { tabId });
    return true;
  } catch (err) {
    Logger.error('Failed to switch tab', { tabId, error: err.message, errorStack: err.stack });
    return false;
  }
}

async function waitForTabLoad(tabId, timeout = CONFIG.TAB_LOAD_TIMEOUT) {
  return new Promise((resolve, reject) => {
    const timer = setTimeout(() => {
      chrome.tabs.onUpdated.removeListener(listener);
      reject(new Error('Tab load timeout'));
    }, timeout);
    
    const listener = (tabId_, info) => {
      if (tabId_ === tabId && info.status === 'complete') {
        clearTimeout(timer);
        chrome.tabs.onUpdated.removeListener(listener);
        setTimeout(() => resolve(), 2000); // Extra wait for page init
      }
    };
    
    chrome.tabs.onUpdated.addListener(listener);
  });
}

// ==================== Message Building ====================
function buildBasePrompt(team, member) {
  let basePrompt = '';
  
  if (team.sharedPrompt) {
    basePrompt += team.sharedPrompt + '\n\n';
  }
  
  if (member.prompt) {
    basePrompt += '=== 你的角色设定 ===\n';
    basePrompt += member.prompt + '\n\n';
  }
  
  basePrompt += '=== 协作规则 ===\n';
  basePrompt += '1. 你是团队的一员，需要与其他成员协作完成任务\n';
  basePrompt += '2. 如果收到JSON格式的指令，请解析并执行\n';
  basePrompt += '3. 可以使用JSON命令与其他成员交互，格式如：{"command": "指令类型", ...}\n';
  basePrompt += '4. 请使用清晰的结构化格式回复，便于其他成员理解\n';
  
  return basePrompt;
}

function buildFollowUpMessage(team, member, message) {
  // For follow-up messages, just send the message directly without base prompt
  return message;
}

// ==================== Initial Prompts ====================
async function sendInitialPrompts(teamId, memberId) {
  const team = teams[teamId];
  const member = team?.members.find(m => m.id === memberId);
  
  if (!team || !member) {
    throw new Error('Team or member not found');
  }
  
  Logger.info('Sending initial prompts', { teamId, memberId, memberName: member.name });
  
  // 构建完整的初始消息
  let initialMessage = '';
  
  // 1. 团队提示词
  if (team.sharedPrompt) {
    initialMessage += `=== 团队任务与目标 ===\n${team.sharedPrompt}\n\n`;
  }
  
  // 2. 角色提示词
  if (member.prompt) {
    initialMessage += `=== 你的角色设定 ===\n${member.prompt}\n\n`;
  }
  
  // 3. 列出全部的角色和对应的身份标识
  if (team.members && team.members.length > 0) {
    initialMessage += '=== 团队成员列表 ===\n';
    team.members.forEach(m => {
      initialMessage += `- ${m.name}`;
      if (m.identifier) {
        initialMessage += ` (标识: ${m.identifier})`;
      }
      if (m.role && m.role !== 'member') {
        initialMessage += ` [${m.role}]`;
      }
      initialMessage += '\n';
    });
    initialMessage += '\n';
  }
  
  // 4. 协作规则
  initialMessage += '=== 协作规则 ===\n';
  initialMessage += '1. 你是团队的一员，需要与其他成员协作完成任务\n';
  initialMessage += '2. 如果收到JSON格式的指令，请解析并执行\n';
  initialMessage += '3. 可以使用JSON命令与其他成员交互，格式如：{"command": "指令类型", ...}\n';
  initialMessage += '4. 请使用清晰的结构化格式回复，便于其他成员理解\n\n';
  
  // 5. 当前上下文
  initialMessage += '=== 当前上下文 ===\n';
  initialMessage += '这是你的初始设置。请确认你已理解以上信息，并准备好开始协作。\n';
  initialMessage += '你可以回复"已就绪"或提出任何疑问。\n';
  
  // 发送初始消息
  try {
    await sendMessageToMember(teamId, memberId, initialMessage, {
      isInitialPrompt: true,
      deepThink: member.useTeamSettings !== false ? team.settings.deepThink : member.deepThink,
      webSearch: member.useTeamSettings !== false ? team.settings.webSearch : member.webSearch
    });
    
    Logger.info('Initial prompts sent successfully', { teamId, memberId, messageLength: initialMessage.length });
    return true;
  } catch (err) {
    Logger.error('Failed to send initial prompts', { teamId, memberId, error: err.message });
    throw err;
  }
}

// ==================== Message Sending ====================
async function sendMessageToMember(teamId, memberId, message, options = {}) {
  const sessionKey = `${teamId}_${memberId}`;
  const team = teams[teamId];
  const member = team?.members.find(m => m.id === memberId);
  
  if (!team || !member) {
    throw new Error('Team or member not found');
  }
  
  // Log the incoming message for debugging
  Logger.info('sendMessageToMember called', {
    teamId,
    memberId,
    message: typeof message === 'string' ? message.substring(0, 100) : message,
    messageType: typeof message,
    options
  });
  
  // Initialize session state if not exists
  if (!teamSessionState[sessionKey]) {
    teamSessionState[sessionKey] = {
      promptSent: false,
      messages: [],
      active: true
    };
  }
  
  const isFirstMessage = !teamSessionState[sessionKey].promptSent;
  
  // Build message based on whether this is the first message
  let fullMessage;
  if (isFirstMessage) {
    const basePrompt = buildBasePrompt(team, member);
    // 对于初始提示词，添加明确的标记，说明这是设置信息
    fullMessage = basePrompt + '\n\n=== 初始设置确认 ===\n';
    fullMessage += '这是你的初始角色设置和团队信息。请确认你已理解以上信息，并回复"已就绪"或提出任何疑问。\n\n';
    
    // 如果有具体任务消息，则添加
    if (message && message.trim()) {
      fullMessage += '=== 当前任务 ===\n' + message;
    } else {
      fullMessage += '当前暂无具体任务，等待进一步指示。';
    }
    
    teamSessionState[sessionKey].promptSent = true;
    
    Logger.info('First message (initial prompt) built', {
      teamId,
      memberId,
      basePromptLength: basePrompt.length,
      messageLength: message ? message.length : 0,
      fullMessageLength: fullMessage.length,
      isInitialPrompt: true
    });
  } else {
    fullMessage = buildFollowUpMessage(team, member, message || '');
    Logger.info('Follow-up message built', { teamId, memberId, messageLength: fullMessage.length });
  }
  
  // Store the message in conversation history
  // Use safe message value to avoid undefined
  const safeMessage = typeof message === 'string' ? message :
                     (message === undefined || message === null ? '' : String(message));
  storeMessage(teamId, memberId, 'user', safeMessage);
  
  // Create tab if needed
  if (!member.tabId) {
    await createMemberTab(teamId, memberId);
    await waitForTabLoad(member.tabId);
  }
  
  // Determine settings: member-specific > team settings
  let deepThinkEnabled, webSearchEnabled;
  
  // Check if member uses team settings (default true if not specified)
  if (member.useTeamSettings !== false) {
    // Use team settings
    deepThinkEnabled = team.settings.deepThink ?? false;
    webSearchEnabled = team.settings.webSearch ?? false;
  } else {
    // Use member-specific settings
    deepThinkEnabled = member.deepThink ?? false;
    webSearchEnabled = member.webSearch ?? false;
  }
  
  // Allow options to override
  if (options.deepThink !== undefined) deepThinkEnabled = options.deepThink;
  if (options.webSearch !== undefined) webSearchEnabled = options.webSearch;
  
  // Send message via content script
  try {
    // Ensure tab is loaded before sending message
    if (member.tabId) {
      try {
        // Check if tab exists and is accessible
        const tab = await chrome.tabs.get(member.tabId);
        if (tab.status === 'complete') {
          // Switch to the member's tab before sending message
          await switchToTab(member.tabId);
          
          try {
            await chrome.tabs.sendMessage(member.tabId, {
              type: 'SEND_MESSAGE',
              payload: {
                text: fullMessage,
                deepThink: deepThinkEnabled,
                webSearch: webSearchEnabled
              }
            });
            
            Logger.info('Message sent to member', {
              teamId,
              memberId,
              isFirstMessage,
              messageLength: fullMessage.length
            });
            
            // Update member status
            ProgressManager.updateMemberStatus(teamId, memberId, 'sending', {
              lastMessage: message.substring(0, 100)
            });
            
            return { success: true, isFirstMessage };
          } catch (sendErr) {
            // Check if error is "Receiving end does not exist"
            if (sendErr.message && sendErr.message.includes('Receiving end does not exist')) {
              Logger.warn('Content script not ready, waiting and retrying', { teamId, memberId });
              // Wait a bit for content script to load
              await sleep(2000);
              // Retry sending
              return await sendMessageToMember(teamId, memberId, message, options);
            }
            throw sendErr;
          }
        } else {
          // Tab not fully loaded, wait for it
          await waitForTabLoad(member.tabId);
          // Retry sending
          return await sendMessageToMember(teamId, memberId, message, options);
        }
      } catch (tabErr) {
        // Tab might be closed or inaccessible, recreate it
        Logger.warn('Tab inaccessible, recreating', { teamId, memberId, error: tabErr.message });
        await createMemberTab(teamId, memberId);
        await waitForTabLoad(member.tabId);
        // Retry sending
        return await sendMessageToMember(teamId, memberId, message, options);
      }
    } else {
      // No tab exists, create one
      await createMemberTab(teamId, memberId);
      await waitForTabLoad(member.tabId);
      // Retry sending
      return await sendMessageToMember(teamId, memberId, message, options);
    }
  } catch (err) {
    Logger.error('Failed to send message', { teamId, memberId, error: err.message, errorStack: err.stack });
    throw err;
  }
}

// Track active conversations per team
const activeConversations = {};
const messageQueue = {};

async function broadcastToTeam(teamId, message, options = {}) {
  const team = teams[teamId];
  if (!team || !team.members.length) {
    throw new Error('Team has no members');
  }
  
  // Ensure message is not undefined
  const safeMessage = typeof message === 'string' ? message :
                     (message === undefined || message === null ? '' : String(message));
  
  Logger.info('broadcastToTeam called', {
    teamId,
    teamName: team.name,
    message: typeof safeMessage === 'string' ? safeMessage.substring(0, 100) : safeMessage,
    messageType: typeof safeMessage,
    memberCount: team.members.length,
    options
  });
  
  const maxConcurrent = team.settings.maxConcurrentConversations || 0;
  const results = [];
  
  // If no limit or limit is 0, send to all members
  if (maxConcurrent === 0) {
    for (const member of team.members) {
      try {
        const result = await sendMessageToMember(teamId, member.id, safeMessage, options);
        results.push({ memberId: member.id, success: true, result });
      } catch (err) {
        results.push({ memberId: member.id, success: false, error: err.message });
      }
      
      // Small delay between sends
      if (team.settings.autoSwitch !== false) {
        await sleep(500);
      }
    }
  } else {
    // With limit: process members in batches
    const members = [...team.members];
    let batchIndex = 0;
    
    while (members.length > 0) {
      const batch = members.splice(0, maxConcurrent);
      batchIndex++;
      
      Logger.info(`Processing batch ${batchIndex} with ${batch.length} members`, { teamId });
      
      // Send to current batch
      for (const member of batch) {
        try {
          const result = await sendMessageToMember(teamId, member.id, safeMessage, options);
          results.push({ memberId: member.id, success: true, result });
        } catch (err) {
          results.push({ memberId: member.id, success: false, error: err.message });
        }
        
        // Use team's send interval setting for delay between sends
        const sendInterval = team.settings.sendInterval || CONFIG.DEFAULT_SEND_INTERVAL;
        if (team.settings.autoSwitch !== false) {
          await sleep(sendInterval);
        }
      }
      
      // Wait for batch to complete before next batch
      if (members.length > 0) {
        Logger.info(`Batch ${batchIndex} complete. Waiting for next batch...`, { teamId });
        // Wait for the batch members to complete their tasks
        await waitForBatchCompletion(teamId, batch);
      }
    }
  }
  
  Logger.info('Broadcast complete', { teamId, messageLength: safeMessage.length, results });
  return results;
}

async function waitForBatchCompletion(teamId, batchMembers) {
  const maxWaitTime = 60000; // Max 60 seconds wait
  const checkInterval = 2000; // Check every 2 seconds
  const startTime = Date.now();
  
  while (Date.now() - startTime < maxWaitTime) {
    const allComplete = batchMembers.every(member => {
      const sessionKey = `${teamId}_${member.id}`;
      // Check if member has pending responses or is still processing
      return isMemberIdle(teamId, member.id);
    });
    
    if (allComplete) {
      return;
    }
    
    await sleep(checkInterval);
  }
  
  Logger.warn('Batch completion wait timeout', { teamId });
}

function isMemberIdle(teamId, memberId) {
  // Check member status in progress tracker
  const progress = teamProgress[teamId];
  if (!progress || !progress.members[memberId]) {
    return true;
  }
  
  const status = progress.members[memberId].status;
  // Consider member idle if status is completed, idle, or error
  return ['completed', 'idle', 'error'].includes(status);
}

// ==================== Conversation History ====================
function storeMessage(teamId, memberId, role, content) {
  const sessionKey = `${teamId}_${memberId}`;
  
  // Ensure content is a string, not undefined
  const safeContent = typeof content === 'string' ? content :
                     (content === undefined || content === null ? '' : String(content));
  
  if (!conversationHistory[sessionKey]) {
    conversationHistory[sessionKey] = [];
  }
  
  conversationHistory[sessionKey].push({
    role,
    content: safeContent,
    timestamp: Date.now()
  });
  
  // Also store in session state for backward compatibility
  if (!teamSessionState[sessionKey]) {
    teamSessionState[sessionKey] = {
      promptSent: false,
      messages: [],
      active: true
    };
  }
  
  teamSessionState[sessionKey].messages.push({
    role,
    content: safeContent,
    timestamp: Date.now()
  });
}

function getConversationHistory(teamId, memberId) {
  const sessionKey = `${teamId}_${memberId}`;
  return conversationHistory[sessionKey] || [];
}

// Clear conversation history for a team or specific member
function clearConversationHistory(teamId, memberId = null) {
  if (memberId) {
    const sessionKey = `${teamId}_${memberId}`;
    delete conversationHistory[sessionKey];
    delete teamSessionState[sessionKey];
  } else {
    // Clear all members in the team
    Object.keys(conversationHistory).forEach(key => {
      if (key.startsWith(`${teamId}_`)) {
        delete conversationHistory[key];
      }
    });
    Object.keys(teamSessionState).forEach(key => {
      if (key.startsWith(`${teamId}_`)) {
        delete teamSessionState[key];
      }
    });
  }
}

// ==================== JSON Command Processing ====================
function parseJsonCommand(text) {
  if (!text || typeof text !== 'string') {
    return null;
  }
  
  // 清理文本，移除可能的前后空白
  const cleanText = text.trim();
  
  // 检查是否是示例文本（包含示例关键词）
  const exampleKeywords = ['示例', '例子', '例如', '比如', '如：', '如:', '格式如', '可以使用以下JSON命令'];
  const isExampleText = exampleKeywords.some(keyword => cleanText.includes(keyword));
  if (isExampleText) {
    Logger.debug('跳过示例文本，不解析为JSON命令', { text: cleanText.substring(0, 100) });
    return null;
  }
  
  try {
    // 方法1：尝试查找完整的JSON代码块（```json ... ```）
    const codeBlockMatch = cleanText.match(/```json\s*([\s\S]*?)```/);
    if (codeBlockMatch) {
      const jsonStr = codeBlockMatch[1].trim();
      // 验证JSON是否完整（检查括号匹配）
      if (isCompleteJson(jsonStr)) {
        const parsed = JSON.parse(jsonStr);
        if (isValidCommand(parsed)) {
          return parsed;
        }
      }
    }
    
    // 方法2：尝试查找文本末尾的JSON对象
    // 首先查找最后一个{和最后一个}的位置
    const lastOpenBrace = cleanText.lastIndexOf('{');
    const lastCloseBrace = cleanText.lastIndexOf('}');
    
    if (lastOpenBrace !== -1 && lastCloseBrace !== -1 && lastOpenBrace < lastCloseBrace) {
      const potentialJson = cleanText.substring(lastOpenBrace, lastCloseBrace + 1);
      
      // 检查是否是完整的JSON（检查括号匹配）
      if (isCompleteJson(potentialJson)) {
        const parsed = JSON.parse(potentialJson);
        if (isValidCommand(parsed)) {
          return parsed;
        }
      }
    }
    
    // 方法3：使用测试插件的正则表达式模式匹配JSON对象
    // 这个模式可以匹配嵌套的JSON对象：/\{(?:[^{}]|(?:\{[^{}]*\}))*\}/g
    const jsonMatch = cleanText.match(/\{(?:[^{}]|(?:\{[^{}]*\}))*\}/g);
    if (jsonMatch) {
      // 取最后一个JSON对象（通常是最新的/末尾的）
      const lastJson = jsonMatch[jsonMatch.length - 1];
      if (isCompleteJson(lastJson)) {
        const parsed = JSON.parse(lastJson);
        if (isValidCommand(parsed)) {
          return parsed;
        }
      }
      
      // 如果最后一个不完整，尝试前面的
      for (let i = jsonMatch.length - 1; i >= 0; i--) {
        if (isCompleteJson(jsonMatch[i])) {
          const parsed = JSON.parse(jsonMatch[i]);
          if (isValidCommand(parsed)) {
            return parsed;
          }
        }
      }
    }
    
    // 方法4：尝试查找特定字段的JSON（向后兼容）
    const jsonPatterns = [
      /\{[\s\S]*?"command"[\s\S]*?\}/,  // 包含"command"字段
      /\{[\s\S]*?"options"[\s\S]*?\}/,  // 包含"options"字段
      /\{[\s\S]*?"type"\s*:\s*"send"[\s\S]*?\}/,  // 包含"type":"send"
      /\{[\s\S]*?"type"\s*:\s*"ask"[\s\S]*?\}/,   // 包含"type":"ask"
    ];
    
    for (const pattern of jsonPatterns) {
      const match = cleanText.match(pattern);
      if (match) {
        const jsonStr = match[0];
        if (isCompleteJson(jsonStr)) {
          const parsed = JSON.parse(jsonStr);
          if (isValidCommand(parsed)) {
            return parsed;
          }
        }
      }
    }
    
  } catch (e) {
    // Not valid JSON
    Logger.debug('Failed to parse JSON command', {
      text: cleanText.substring(0, 200),
      error: e.message
    });
  }
  
  return null;
}

// 验证解析的JSON是否是有效的命令
function isValidCommand(obj) {
  if (!obj || typeof obj !== 'object') {
    return false;
  }
  
  // 检查是否是有效的命令格式
  const hasCommandField = obj.command && typeof obj.command === 'string';
  const hasTypeField = obj.type && typeof obj.type === 'string';
  const hasOptionsField = obj.options && Array.isArray(obj.options);
  
  // 有效的命令必须至少包含以下字段之一
  if (!hasCommandField && !hasTypeField && !hasOptionsField) {
    return false;
  }
  
  // 检查命令类型是否有效
  if (hasCommandField) {
    const validCommands = ['sendTo', 'broadcast', 'complete', 'ask', 'continu'];
    if (!validCommands.includes(obj.command)) {
      return false;
    }
  }
  
  // 检查类型是否有效
  if (hasTypeField) {
    const validTypes = ['send', 'ask'];
    if (!validTypes.includes(obj.type)) {
      return false;
    }
  }
  
  return true;
}

// 辅助函数：检查JSON字符串是否完整（括号匹配）
function isCompleteJson(str) {
  if (!str || typeof str !== 'string') {
    return false;
  }
  
  // 检查括号匹配
  let braceCount = 0;
  let bracketCount = 0;
  let inString = false;
  let escapeNext = false;
  
  for (let i = 0; i < str.length; i++) {
    const char = str[i];
    
    if (escapeNext) {
      escapeNext = false;
      continue;
    }
    
    if (char === '\\') {
      escapeNext = true;
      continue;
    }
    
    if (char === '"' && !escapeNext) {
      inString = !inString;
      continue;
    }
    
    if (!inString) {
      if (char === '{') braceCount++;
      if (char === '}') braceCount--;
      if (char === '[') bracketCount++;
      if (char === ']') bracketCount--;
      
      // 如果括号计数为负，说明括号不匹配
      if (braceCount < 0 || bracketCount < 0) {
        return false;
      }
    }
  }
  
  // 检查是否在字符串中结束（不完整的字符串）
  if (inString) {
    return false;
  }
  
  // 最终括号应该匹配
  return braceCount === 0 && bracketCount === 0;
}

async function executeJsonCommand(teamId, command, fromMemberId) {
  const team = teams[teamId];
  if (!team) return { error: 'Team not found' };
  
  // Ensure command has required fields
  const safeCommand = {
    ...command,
    message: command.message || '',
    result: command.result || '',
    target: command.target || '',
    type: command.type || '',
    options: command.options || []
  };
  
  // Handle new format: {"options": ["推荐选项", "可选选项1", "可选选项2"]}
  if (safeCommand.options && Array.isArray(safeCommand.options) && safeCommand.options.length > 0) {
    // Check if auto-continue is enabled for this team
    const autoContinueEnabled = team.settings.autoContinue !== false;
    
    if (autoContinueEnabled) {
      // Automatically send the first option (recommended option)
      const recommendedOption = safeCommand.options[0];
      Logger.info('Auto-sending recommended option', {
        teamId, fromMemberId,
        options: safeCommand.options,
        selected: recommendedOption,
        autoContinueEnabled
      });
      
      // Wait for AI to complete output before sending next message
      // Use team's send interval or default 3 seconds
      const sendInterval = team.settings.sendInterval || CONFIG.DEFAULT_SEND_INTERVAL;
      const waitTime = Math.max(3000, sendInterval); // At least 3 seconds
      Logger.info('Waiting before auto-sending option', {
        teamId, fromMemberId, waitTime, sendInterval
      });
      await sleep(waitTime);
      
      // Send the recommended option back to the same member
      await sendMessageToMember(teamId, fromMemberId, recommendedOption);
      return { success: true, action: 'auto_send_option', option: recommendedOption, waited: waitTime };
    } else {
      Logger.info('Options detected but auto-continue is disabled', {
        teamId, fromMemberId,
        options: safeCommand.options,
        autoContinueEnabled
      });
      return { success: true, action: 'options_detected_but_not_auto_sent', options: safeCommand.options };
    }
  }
  
  // Handle new format: {"type":"send", "target":"成员名称", "message":"要发送的内容"}
  if (safeCommand.type === 'send' && safeCommand.target && safeCommand.message) {
    const targetMember = team.members.find(m => m.name === safeCommand.target);
    if (targetMember) {
      await sendMessageToMember(teamId, targetMember.id, safeCommand.message);
      return { success: true, action: 'sent_to_member', target: safeCommand.target };
    }
    return { error: 'Target member not found: ' + safeCommand.target };
  }
  
  // Handle legacy format with "command" field
  switch (safeCommand.command) {
    case 'sendTo':
      const targetMember = team.members.find(m => m.name === safeCommand.target);
      if (targetMember) {
        await sendMessageToMember(teamId, targetMember.id, safeCommand.message);
        return { success: true, action: 'sent', target: safeCommand.target };
      }
      return { error: 'Target member not found' };
      
    case 'broadcast':
      await broadcastToTeam(teamId, safeCommand.message);
      return { success: true, action: 'broadcast' };
      
    case 'complete':
      ProgressManager.updateMemberStatus(teamId, fromMemberId, 'completed', {
        result: safeCommand.result
      });
      return { success: true, action: 'marked_complete' };
      
    case 'ask':
      // 向使用者返回问题等待回应
      // 这里需要将问题发送给用户界面，等待用户回应
      // 暂时先记录日志，后续可以扩展为向popup发送通知
      Logger.info('Ask command received - question for user', {
        teamId, fromMemberId,
        question: safeCommand.question
      });
      
      // 发送通知到popup或options页面
      try {
        chrome.runtime.sendMessage({
          type: 'user_question',
          teamId,
          memberId: fromMemberId,
          question: safeCommand.question
        });
      } catch (e) {
        Logger.warn('Failed to send user question notification', { error: e.message });
      }
      
      return { success: true, action: 'ask_question', question: safeCommand.question };
      
    case 'continu':
      // 未完成工作，插件自动在输入框输入继续工作并发送
      Logger.info('Continu command received - auto sending continue work', {
        teamId, fromMemberId,
        send: safeCommand.send || '继续工作'
      });
      
      // 使用send字段的内容，默认为"继续工作"
      const continueMessage = safeCommand.send || '继续工作';
      
      // 等待一段时间确保AI完成输出
      const sendInterval = team.settings.sendInterval || CONFIG.DEFAULT_SEND_INTERVAL;
      const waitTime = Math.max(2000, sendInterval); // 至少2秒
      await sleep(waitTime);
      
      // 发送继续工作的消息
      await sendMessageToMember(teamId, fromMemberId, continueMessage);
      return { success: true, action: 'auto_continue', message: continueMessage, waited: waitTime };
      
    default:
      return { error: 'Unknown command: ' + safeCommand.command };
  }
}

// ==================== Progress Management ====================
const ProgressManager = {
  initTeamProgress(teamId) {
    teamProgress[teamId] = {
      teamId,
      status: 'running',
      members: {},
      startTime: Date.now()
    };
  },
  
  updateMemberStatus(teamId, memberId, status, data = {}) {
    if (!teamProgress[teamId]) {
      this.initTeamProgress(teamId);
    }
    
    teamProgress[teamId].members[memberId] = {
      status,
      lastUpdate: Date.now(),
      ...data
    };
  },
  
  getTeamProgress(teamId) {
    return teamProgress[teamId];
  },
  
  interruptTeam(teamId) {
    if (teamProgress[teamId]) {
      teamProgress[teamId].status = 'interrupted';
      teamProgress[teamId].endTime = Date.now();
    }
  },
  
  resetTeamProgress(teamId) {
    delete teamProgress[teamId];
  }
};

// ==================== Message Handlers ====================
chrome.runtime.onMessage.addListener((msg, sender, sendResponse) => {
  const handle = async () => {
    switch (msg.type) {
      // Team management
      case 'GET_TEAMS':
        return teams;
        
      case 'CREATE_TEAM':
        return createTeam(msg.teamData);
        
      case 'UPDATE_TEAM':
        return updateTeam(msg.teamId, msg.updates);
        
      case 'DELETE_TEAM':
        deleteTeam(msg.teamId);
        return { success: true };
        
      // Member management
      case 'ADD_MEMBER':
        return addMember(msg.teamId, msg.memberData);
        
      case 'UPDATE_MEMBER':
        return updateMember(msg.teamId, msg.memberId, msg.updates);
        
      case 'REMOVE_MEMBER':
        removeMember(msg.teamId, msg.memberId);
        return { success: true };
        
      // Messaging
      case 'SEND_TO_MEMBER':
        return await sendMessageToMember(msg.teamId, msg.memberId, msg.message, msg.options);
        
      case 'BROADCAST_TEAM':
        return await broadcastToTeam(msg.teamId, msg.message, msg.options);
        
      case 'SERIAL_SEND':
        return await handleSerialSend(msg.teamId, msg.startMemberId, msg.message);
        
      // Team session operations
      case 'START_TEAM_CHAT':
        const team = teams[msg.teamId];
        if (!team) {
          Logger.error('Team not found for START_TEAM_CHAT', { teamId: msg.teamId });
          return { error: 'Team not found' };
        }
        
        Logger.info('Starting team chat', {
          teamId: msg.teamId,
          teamName: team.name,
          memberCount: team.members.length,
          initialMessage: msg.initialMessage
        });
        
        ProgressManager.initTeamProgress(msg.teamId);
        
        // 轮流打开标签页并发送初始消息
        let createdCount = 0;
        let reusedCount = 0;
        const results = [];
        
        // 使用团队的发送间隔或默认值
        const sendInterval = team.settings.sendInterval || CONFIG.DEFAULT_SEND_INTERVAL;
        const tabOpenInterval = Math.max(3000, sendInterval); // 至少3秒间隔
        
        Logger.info('Starting sequential tab opening', {
          teamId: msg.teamId,
          memberCount: team.members.length,
          tabOpenInterval,
          sendInterval
        });
        
        // 按顺序处理每个成员
        for (let i = 0; i < team.members.length; i++) {
          const member = team.members[i];
          Logger.info('Processing member sequentially', {
            index: i + 1,
            total: team.members.length,
            memberId: member.id,
            memberName: member.name
          });
          
          // 检查成员是否已经有标签页
          const hadTabBefore = !!member.tabId;
          const tab = await ensureMemberTab(msg.teamId, member.id, { autoSendInitialPrompt: false });
          
          if (tab) {
            if (hadTabBefore) {
              reusedCount++;
              Logger.info('Reused existing tab', { memberId: member.id, tabId: tab.id });
            } else {
              createdCount++;
              Logger.info('Created new tab', { memberId: member.id, tabId: tab.id });
            }
            
            // 等待标签页加载完成（ensureMemberTab内部会等待）
            // 这里额外等待一段时间确保页面完全初始化
            await sleep(2000);
            
            // 发送初始提示词给这个成员
            try {
              await sendInitialPrompts(msg.teamId, member.id);
              Logger.info('Initial prompts sent to member', { memberId: member.id, memberName: member.name });
              results.push({ memberId: member.id, status: 'success' });
            } catch (err) {
              Logger.error('Failed to send initial prompts to member', {
                memberId: member.id,
                error: err.message
              });
              results.push({ memberId: member.id, status: 'error', error: err.message });
            }
          } else {
            Logger.error('Failed to ensure tab for member', { memberId: member.id });
            results.push({ memberId: member.id, status: 'error', error: 'Tab creation failed' });
          }
          
          // 如果不是最后一个成员，等待间隔时间再处理下一个
          if (i < team.members.length - 1) {
            Logger.info('Waiting before processing next member', {
              currentIndex: i + 1,
              nextIndex: i + 2,
              waitTime: tabOpenInterval
            });
            await sleep(tabOpenInterval);
          }
        }
        
        Logger.info('Sequential tab opening complete', {
          totalMembers: team.members.length,
          createdCount,
          reusedCount,
          successCount: results.filter(r => r.status === 'success').length,
          errorCount: results.filter(r => r.status === 'error').length
        });
        
        // 所有成员都处理完成后，发送团队启动消息
        const startupMessage = "团队已启动，所有成员已就绪，可以开始协作。";
        Logger.info('Sending final startup message', { teamId: msg.teamId, message: startupMessage });
        await broadcastToTeam(msg.teamId, startupMessage);
        
        // 如果有初始消息，也发送给所有成员
        if (msg.initialMessage) {
          Logger.info('Sending initial task message', { teamId: msg.teamId, message: msg.initialMessage });
          await broadcastToTeam(msg.teamId, msg.initialMessage);
        }
        
        // 发送团队状态更新到所有成员标签页
        await broadcastTeamStatus(msg.teamId, true);
        
        return {
          success: true,
          memberCount: team.members.length,
          tabsCreated: createdCount,
          tabsReused: reusedCount,
          startupMessageSent: true,
          initialMessageSent: !!msg.initialMessage,
          results: results
        };
        
      case 'STOP_TEAM_CHAT':
        const stopTeam = teams[msg.teamId];
        if (stopTeam) {
          // 先发送团队状态更新（关闭）
          await broadcastTeamStatus(msg.teamId, false);
          
          for (const member of stopTeam.members) {
            closeMemberTab(msg.teamId, member.id);
          }
        }
        // Clear session state
        clearConversationHistory(msg.teamId);
        ProgressManager.interruptTeam(msg.teamId);
        return { success: true };
        
      // Progress
      case 'GET_PROGRESS':
        return ProgressManager.getTeamProgress(msg.teamId);
        
      case 'INTERRUPT_TEAM':
        ProgressManager.interruptTeam(msg.teamId);
        return { success: true };
        
      case 'RESET_PROGRESS':
        ProgressManager.resetTeamProgress(msg.teamId);
        return { success: true };
        
      // Conversation history
      case 'GET_CONVERSATION_HISTORY':
        return {
          history: getConversationHistory(msg.teamId, msg.memberId),
          session: teamSessionState[`${msg.teamId}_${msg.memberId}`] || null
        };
        
      case 'GET_ALL_CONVERSATIONS':
        const teamConvos = {};
        const targetTeam = teams[msg.teamId];
        if (targetTeam && targetTeam.members) {
          targetTeam.members.forEach(member => {
            teamConvos[member.id] = {
              memberName: member.name,
              history: getConversationHistory(msg.teamId, member.id)
            };
          });
        }
        return teamConvos;
        
      case 'CLEAR_CONVERSATION_HISTORY':
        clearConversationHistory(msg.teamId, msg.memberId);
        return { success: true };
        
      // Logs
      case 'GET_LOGS':
        return teamLogs;
        
      case 'CLEAR_LOGS':
        teamLogs = [];
        await chrome.storage.local.set({ teamLogs: [] });
        return { success: true };
        
      // Data export/import
      case 'EXPORT_DATA':
        return {
          teams,
          logs: teamLogs,
          sessionState: teamSessionState,
          conversations: conversationHistory,
          exportTime: Date.now()
        };
        
      case 'IMPORT_DATA':
        if (msg.data.teams) {
          teams = msg.data.teams;
          saveTeams();
        }
        if (msg.data.logs) {
          teamLogs = msg.data.logs;
          await chrome.storage.local.set({ teamLogs });
        }
        if (msg.data.sessionState) {
          teamSessionState = msg.data.sessionState;
        }
        if (msg.data.conversations) {
          conversationHistory = msg.data.conversations;
        }
        return { success: true };
        
      // Content script messages
      case 'REPLY_RECEIVED':
        if (sender.tab) {
          const tabInfo = tabMemberMap[sender.tab.id];
          if (tabInfo) {
            const { teamId, memberId } = tabInfo;
            
            // 存储AI回复到对话历史
            const replyText = msg.payload?.text || '';
            storeMessage(teamId, memberId, 'assistant', replyText);
            
            // Parse JSON command from reply
            const command = parseJsonCommand(replyText);
            if (command) {
              Logger.info('JSON command detected', { teamId, memberId, command });
              
              const result = await executeJsonCommand(teamId, command, memberId);
              Logger.info('Command executed', { teamId, command, result });
              
              // After command execution, check if there's a next task in the queue
              if (result && result.success) {
                await processNextTask(teamId, memberId);
              }
            } else {
              // No command detected, check for task completion keywords
              if (isTaskCompletionDetected(replyText)) {
                await processNextTask(teamId, memberId);
              }
            }
            
            ProgressManager.updateMemberStatus(teamId, memberId, 'completed', {
              lastReply: replyText.substring(0, 200)
            });
            
            // 检查是否是串行发送的一部分
            const serialKey = `${teamId}_serial`;
            if (serialSessions && serialSessions[serialKey] && serialSessions[serialKey].status === 'running') {
              await handleSerialReply(teamId, memberId, replyText);
            }
            
            // 自动转发消息给其他成员（如果启用）
            try {
              await autoForwardMessage(teamId, memberId, replyText, {
                strategy: 'all' // 默认转发给所有其他成员
              });
            } catch (err) {
              Logger.error('Auto-forwarding failed', {
                teamId, memberId, error: err.message
              });
            }
          
            // Broadcast conversation update to all listening contexts
            chrome.runtime.sendMessage({
              type: 'CONVERSATION_UPDATED',
              teamId,
              memberId,
              message: {
                role: 'assistant',
                content: replyText,
                timestamp: Date.now()
              }
            }).catch(() => {});
          }
        }
        return { success: true };
        
      case 'GET_CONVERSATION_FROM_CONTENT':
        if (sender.tab) {
          const tabInfo = tabMemberMap[sender.tab.id];
          if (tabInfo) {
            const history = getConversationHistory(tabInfo.teamId, tabInfo.memberId);
            return { history };
          }
        }
        return { history: [] };
        
      case 'MESSAGE_SENT_FROM_CONTENT':
        if (sender.tab) {
          const tabInfo = tabMemberMap[sender.tab.id];
          if (tabInfo) {
            const { teamId, memberId } = tabInfo;
            
            // Broadcast that a message was sent
            chrome.runtime.sendMessage({
              type: 'CONVERSATION_UPDATED',
              teamId,
              memberId,
              message: {
                role: 'user',
                content: msg.payload?.text || '',
                timestamp: Date.now()
              }
            }).catch(() => {});
          }
        }
        return { success: true };
        
      default:
        return { error: 'Unknown message type: ' + msg.type };
    }
  };
  
  // Handle the message asynchronously
  const responsePromise = handle().then(result => {
    return result;
  }).catch(err => {
    Logger.error('Message handler error', { type: msg.type, error: err.message });
    return { error: err.message };
  });

  // Send response when ready
  responsePromise.then(result => {
    try {
      sendResponse(result);
    } catch (e) {
      // Channel already closed, ignore
      Logger.debug('Response channel closed', { type: msg.type });
    }
  });

  // Return true to indicate we'll respond asynchronously
  return true;
});


// ==================== Tab Cleanup ====================
chrome.tabs.onRemoved.addListener((tabId) => {
  const tabInfo = tabMemberMap[tabId];
  if (tabInfo) {
    const { teamId, memberId } = tabInfo;
    const team = teams[teamId];
    if (team) {
      const member = team.members.find(m => m.id === memberId);
      if (member) {
        member.tabId = null;
        saveTeams();
      }
    }
    delete tabMemberMap[tabId];
    if (teamTabs[teamId]) {
      delete teamTabs[teamId][memberId];
    }
    Logger.info('Tab closed', { tabId, teamId, memberId });
  }
});

// ==================== Initialization ====================
chrome.runtime.onStartup.addListener(() => {
  try {
    loadTeams();
    Logger.info('Service worker started');
  } catch (err) {
    console.error('Error in onStartup listener:', err);
  }
});

chrome.runtime.onInstalled.addListener(() => {
  try {
    loadTeams();
    Logger.info('Extension installed/updated');
  } catch (err) {
    console.error('Error in onInstalled listener:', err);
  }
});

// Load data on startup
try {
  loadTeams();
} catch (err) {
  console.error('Error loading teams on startup:', err);
}

// ==================== Utils ====================
function sleep(ms) {
  return new Promise(resolve => setTimeout(resolve, ms));
}

// ==================== Task Queue ====================
// Task queue management for teams
const taskQueues = {};
const taskAutoSend = {};

function addTaskToQueue(teamId, memberId, task) {
  const queueKey = `${teamId}_${memberId}`;
  if (!taskQueues[queueKey]) {
    taskQueues[queueKey] = [];
  }
  
  const taskItem = {
    id: 'task_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9),
    content: task,
    status: 'pending',
    createdAt: Date.now()
  };
  
  taskQueues[queueKey].push(taskItem);
  Logger.info('Task added to queue', { teamId, memberId, taskId: taskItem.id });
  return taskItem;
}

function getTaskQueue(teamId, memberId) {
  const queueKey = `${teamId}_${memberId}`;
  return taskQueues[queueKey] || [];
}

function removeTaskFromQueue(teamId, memberId, taskId) {
  const queueKey = `${teamId}_${memberId}`;
  if (taskQueues[queueKey]) {
    taskQueues[queueKey] = taskQueues[queueKey].filter(t => t.id !== taskId);
  }
}

function clearTaskQueue(teamId, memberId) {
  const queueKey = `${teamId}_${memberId}`;
  delete taskQueues[queueKey];
}

function setAutoSendEnabled(teamId, memberId, enabled) {
  const queueKey = `${teamId}_${memberId}`;
  taskAutoSend[queueKey] = enabled;
}

function isAutoSendEnabled(teamId, memberId) {
  const queueKey = `${teamId}_${memberId}`;
  return taskAutoSend[queueKey] !== false; // Default to true
}

async function processNextTask(teamId, memberId) {
  if (!isAutoSendEnabled(teamId, memberId)) {
    Logger.info('Auto-send disabled, skipping task processing', { teamId, memberId });
    return;
  }
  
  const queueKey = `${teamId}_${memberId}`;
  const queue = taskQueues[queueKey];
  
  if (!queue || queue.length === 0) {
    Logger.info('No tasks in queue', { teamId, memberId });
    return;
  }
  
  // Find the first pending task
  const pendingTaskIndex = queue.findIndex(t => t.status === 'pending');
  if (pendingTaskIndex === -1) {
    Logger.info('No pending tasks in queue', { teamId, memberId });
    return;
  }
  
  const task = queue[pendingTaskIndex];
  task.status = 'sending';
  
  try {
    Logger.info('Processing next task', { teamId, memberId, taskId: task.id });
    
    // Wait a moment before sending
    await sleep(2000);
    
    await sendMessageToMember(teamId, memberId, task.content);
    
    task.status = 'completed';
    task.completedAt = Date.now();
    
    // Move to completed section (optional: keep for history)
    Logger.info('Task completed and sent', { teamId, memberId, taskId: task.id });
    
    // Notify UI
    chrome.runtime.sendMessage({
      type: 'TASK_COMPLETED',
      teamId,
      memberId,
      task
    }).catch(() => {});
    
  } catch (err) {
    Logger.error('Failed to process task', { teamId, memberId, taskId: task.id, error: err.message });
    task.status = 'error';
    task.error = err.message;
  }
}

function isTaskCompletionDetected(replyText) {
  if (!replyText) return false;
  
  // Keywords that indicate task completion
  const completionKeywords = [
    '任务完成',
    '已完成',
    '任务已结束',
    'task completed',
    'task done',
    'finished',
    '完成',
    '结束任务',
    '工作完成',
    'finished the task',
    'completed successfully'
  ];
  
  const lowerText = replyText.toLowerCase();
  return completionKeywords.some(keyword => lowerText.includes(keyword.toLowerCase()));
}

// ==================== Serial Send Function ====================
async function handleSerialSend(teamId, startMemberId, message) {
  try {
    const team = teams[teamId];
    if (!team) {
      throw new Error('Team not found');
    }

    const startMember = team.members.find(m => m.id === startMemberId);
    if (!startMember) {
      throw new Error('Start member not found');
    }

    Logger.info('Starting serial send', {
      teamId,
      teamName: team.name,
      startMemberId,
      startMemberName: startMember.name,
      messageLength: message.length
    });

    // 存储串行发送状态
    const serialKey = `${teamId}_serial`;
    serialSessions = serialSessions || {};
    serialSessions[serialKey] = {
      teamId,
      startMemberId,
      message,
      context: message, // 初始上下文
      completedMembers: new Set(),
      currentMemberId: startMemberId,
      status: 'running',
      startTime: Date.now()
    };

    // 开始串行发送流程
    await processSerialStep(teamId, startMemberId, message, message);

    return {
      success: true,
      message: 'Serial send started',
      startMember: startMember.name
    };
  } catch (error) {
    Logger.error('Serial send failed', { teamId, startMemberId, error: error.message });
    return {
      success: false,
      error: error.message
    };
  }
}

// 全局变量用于存储串行发送状态
let serialSessions = {};

async function processSerialStep(teamId, memberId, originalMessage, context) {
  const team = teams[teamId];
  const member = team?.members.find(m => m.id === memberId);
  
  if (!team || !member) {
    Logger.error('Member not found in serial step', { teamId, memberId });
    return;
  }

  const serialKey = `${teamId}_serial`;
  const session = serialSessions[serialKey];
  
  if (!session || session.status !== 'running') {
    return;
  }

  Logger.info('Processing serial step', {
    teamId,
    memberId,
    memberName: member.name,
    contextLength: context.length
  });

  try {
    // 向当前成员发送消息（附带上下文）
    await sendMessageToMember(teamId, memberId, context, {
      isSerial: true,
      originalMessage,
      context
    });

    // 标记该成员为已处理
    session.completedMembers.add(memberId);
    session.currentMemberId = memberId;
    session.context = context; // 更新上下文（将在收到回复后更新）

    Logger.info('Serial step sent', {
      teamId,
      memberId,
      memberName: member.name,
      completedCount: session.completedMembers.size,
      totalMembers: team.members.length
    });

  } catch (error) {
    Logger.error('Serial step failed', { teamId, memberId, error: error.message });
    // 继续处理下一个成员
    await processNextSerialMember(teamId, memberId, context);
  }
}

async function processNextSerialMember(teamId, currentMemberId, context) {
  const team = teams[teamId];
  const serialKey = `${teamId}_serial`;
  const session = serialSessions[serialKey];
  
  if (!session || session.status !== 'running') {
    return;
  }

  // 查找当前成员的下级
  const subordinates = team.members.filter(m => m.parentId === currentMemberId);
  
  if (subordinates.length === 0) {
    // 没有下级，串行流程结束
    Logger.info('Serial send completed - no more subordinates', {
      teamId,
      currentMemberId,
      totalCompleted: session.completedMembers.size
    });
    
    session.status = 'completed';
    session.endTime = Date.now();
    
    // 发送完成通知
    chrome.runtime.sendMessage({
      type: 'SERIAL_SEND_COMPLETED',
      teamId,
      session: {
        startMemberId: session.startMemberId,
        completedMembers: Array.from(session.completedMembers),
        startTime: session.startTime,
        endTime: session.endTime,
        context: session.context
      }
    }).catch(() => {});
    
    return;
  }

  // 按顺序向下级发送
  for (const subordinate of subordinates) {
    if (!session.completedMembers.has(subordinate.id)) {
      // 等待一小段时间，然后处理下一个下级
      await new Promise(resolve => setTimeout(resolve, 1000));
      await processSerialStep(teamId, subordinate.id, session.message, context);
      return;
    }
  }

  // 所有下级都已处理，向上查找
  const currentMember = team.members.find(m => m.id === currentMemberId);
  if (currentMember?.parentId) {
    // 继续向上级的下级处理
    await processNextSerialMember(teamId, currentMember.parentId, context);
  } else {
    // 到达顶级，流程结束
    Logger.info('Serial send completed - reached top level', {
      teamId,
      totalCompleted: session.completedMembers.size
    });
    
    session.status = 'completed';
    session.endTime = Date.now();
    
    chrome.runtime.sendMessage({
      type: 'SERIAL_SEND_COMPLETED',
      teamId,
      session
    }).catch(() => {});
  }
}

// 在收到回复时更新上下文并继续串行流程
async function handleSerialReply(teamId, memberId, replyText) {
  const serialKey = `${teamId}_serial`;
  const session = serialSessions[serialKey];
  
  if (!session || session.status !== 'running') {
    return;
  }

  // 更新上下文：将回复追加到上下文中
  const updatedContext = `${session.context}\n\n--- ${getMemberName(teamId, memberId)} 的回复 ---\n${replyText}`;
  session.context = updatedContext;

  Logger.info('Serial reply received, updating context', {
    teamId,
    memberId,
    replyLength: replyText.length,
    contextLength: updatedContext.length
  });

  // 继续处理下一个成员
  await processNextSerialMember(teamId, memberId, updatedContext);
}

function getMemberName(teamId, memberId) {
  const team = teams[teamId];
  const member = team?.members.find(m => m.id === memberId);
  return member ? member.name : `成员 ${memberId}`;
}

// ==================== Message Auto-Forwarding ====================
/**
 * 自动转发成员消息给其他成员
 * @param {string} teamId 团队ID
 * @param {string} fromMemberId 发送消息的成员ID
 * @param {string} message 消息内容
 * @param {object} options 转发选项
 */
async function autoForwardMessage(teamId, fromMemberId, message, options = {}) {
  const team = teams[teamId];
  if (!team) {
    Logger.warn('Team not found for auto-forwarding', { teamId });
    return;
  }
  
  // 检查是否启用了自动转发
  if (!team.settings.autoForward) {
    Logger.debug('Auto-forwarding is disabled for team', { teamId });
    return;
  }
  
  // 获取发送消息的成员
  const fromMember = team.members.find(m => m.id === fromMemberId);
  if (!fromMember) {
    Logger.warn('From member not found for auto-forwarding', { teamId, fromMemberId });
    return;
  }
  
  // 确定要转发给哪些成员
  const targetMembers = [];
  
  // 策略1：转发给所有其他成员
  if (options.strategy === 'all' || !options.strategy) {
    targetMembers.push(...team.members.filter(m => m.id !== fromMemberId));
  }
  // 策略2：转发给下级成员
  else if (options.strategy === 'subordinates') {
    const subordinates = team.members.filter(m => m.parentId === fromMemberId);
    targetMembers.push(...subordinates);
  }
  // 策略3：转发给上级成员
  else if (options.strategy === 'superiors') {
    const superiors = [];
    let currentMember = fromMember;
    while (currentMember?.parentId) {
      const superior = team.members.find(m => m.id === currentMember.parentId);
      if (superior) {
        superiors.push(superior);
        currentMember = superior;
      } else {
        break;
      }
    }
    targetMembers.push(...superiors);
  }
  // 策略4：转发给同级成员（共享同一个上级）
  else if (options.strategy === 'peers') {
    const peers = team.members.filter(m =>
      m.id !== fromMemberId &&
      m.parentId === fromMember.parentId
    );
    targetMembers.push(...peers);
  }
  
  if (targetMembers.length === 0) {
    Logger.debug('No target members found for auto-forwarding', {
      teamId, fromMemberId, strategy: options.strategy
    });
    return;
  }
  
  Logger.info('Auto-forwarding message', {
    teamId,
    fromMemberId: fromMemberId,
    fromMemberName: fromMember.name,
    messageLength: message.length,
    targetCount: targetMembers.length,
    strategy: options.strategy || 'all',
    targetMembers: targetMembers.map(m => m.name)
  });
  
  // 构建转发消息
  const forwardMessage = `[转发自 ${fromMember.name}]\n${message}`;
  
  // 向目标成员发送转发消息
  for (const targetMember of targetMembers) {
    try {
      await sendMessageToMember(teamId, targetMember.id, forwardMessage, {
        isForwarded: true,
        fromMemberId,
        fromMemberName: fromMember.name
      });
      
      Logger.info('Message forwarded to member', {
        teamId,
        fromMemberId,
        targetMemberId: targetMember.id,
        targetMemberName: targetMember.name
      });
      
      // 添加延迟以避免同时发送太多消息
      await sleep(1000);
    } catch (err) {
      Logger.error('Failed to forward message to member', {
        teamId,
        fromMemberId,
        targetMemberId: targetMember.id,
        error: err.message
      });
    }
  }
}

// ==================== Tab URL Tracking ====================
// 监听标签页URL变化，更新成员currentUrl
chrome.tabs.onUpdated.addListener((tabId, changeInfo, tab) => {
  // 只处理URL变化
  if (!changeInfo.url || !tab.url) return;
  
  const mapping = tabMemberMap[tabId];
  if (!mapping) return;
  
  const { teamId, memberId } = mapping;
  const team = teams[teamId];
  const member = team?.members.find(m => m.id === memberId);
  
  if (member) {
    member.currentUrl = tab.url;
    saveTeams();
    Logger.debug('Tab URL updated', {
      teamId, memberId, tabId,
      oldUrl: member.currentUrl, newUrl: tab.url
    });
  }
});

// ==================== Initialization ====================
// 加载团队数据
loadTeams();

// 清理无效的标签页映射（当标签页被关闭时）
chrome.tabs.onRemoved.addListener((tabId) => {
  const mapping = tabMemberMap[tabId];
  if (mapping) {
    const { teamId, memberId } = mapping;
    const team = teams[teamId];
    const member = team?.members.find(m => m.id === memberId);
    
    if (member) {
      member.tabId = null;
      member.currentUrl = null;
      saveTeams();
      Logger.info('Tab removed, cleared member tab mapping', { teamId, memberId, tabId });
    }
    
    delete tabMemberMap[tabId];
    delete teamTabs[teamId]?.[memberId];
  }
});
